{
  "name": "smartpages",
  "version": "1.0.0",
  "description": "智能网页文档助手浏览器插件",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node scripts/remove-build-artifact.js",
    "preview": "vite preview",
    "test": "node tests/run-tests.js",
    "verify": "npm test && npm run lint -- --quiet && npm run typecheck && npm run build",
    "video:preview": "remotion preview video/index.jsx",
    "video:render": "remotion render video/index.jsx smartpages-promo video/out/smartpages-promo.mp4",
    "lint": "eslint \"**/*.js\" --ignore-pattern node_modules/ --ignore-pattern dist/ --ignore-pattern libs/",
    "lint:fix": "eslint \"**/*.js\" --ignore-pattern node_modules/ --ignore-pattern dist/ --ignore-pattern libs/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chrome-extension",
    "browser-extension",
    "documentation",
    "ai"
  ],
  "author": "汪鸿儒 (Hongru Wang)",
  "license": "GPL-3.0",
  "main": "diagnostic-tool.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teddy9710/smartpages.git"
  },
  "bugs": {
    "url": "https://github.com/Teddy9710/smartpages/issues"
  },
  "homepage": "https://github.com/Teddy9710/smartpages#readme",
  "devDependencies": {
    "@remotion/cli": "^4.0.469",
    "@types/chrome": "^0.1.40",
    "eslint": "^8.57.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.469",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
