{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-inner-declarations": "off",
    "prefer-const": "warn",
    "no-var": "error"
  },
  "globals": {
    "chrome": "readonly"
  }
}
